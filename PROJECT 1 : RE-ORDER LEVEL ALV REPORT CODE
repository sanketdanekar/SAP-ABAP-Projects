REPORT Z_REORDER_LEVEL_REPORT17.
************************************************************************
* Author                : SANKETD
* PROGRAM NAME          : Z_REORDER_LEVEL_REPORT17
* PACKAGE               : ZPACK_17
* T REQUEST NUMBER      : Y01K903982
* PROGRAM TITLE         : Re-Order Report
* MODULE                : MM
* PROGRAM TYPE          : ALV
* T-CODE                : ZRLR17
* CREATED BY            : SANKET DANDEKAR
* CREATION DATE         : 26/06/2026
**************************************************
TABLES SSCRFIELDS.

PARAMETERS :
  R1 RADIOBUTTON GROUP GRU1 DEFAULT 'X',
  R2 RADIOBUTTON GROUP GRU1.

DATA: S TYPE MARA-MATNR,
      P TYPE MARA-MTART,
      R TYPE MARA-MATKL,
      D TYPE MARC-WERKS.
*DATA: V_WERKS TYPE MARC-WERKS,
*      V_MATNR TYPE MARA-MATNR,
*      V_MTART TYPE T134-MTART,
*      V_MATKL TYPE T023-MATKL.
SELECTION-SCREEN SKIP 1.
SELECT-OPTIONS :S_WERKS FOR D,
                S_MATNR FOR S,
                 S_MTART FOR P,
                 S_MATKL FOR R.

SELECTION-SCREEN SKIP 2.
SELECTION-SCREEN PUSHBUTTON 30(10) BUTTON1 USER-COMMAND FCT1.
SELECTION-SCREEN PUSHBUTTON 60(10) BUTTON2 USER-COMMAND FCT2.

INITIALIZATION.
  BUTTON1 = 'DISPLAY'.
  BUTTON2 = 'EXIT'.

  S_WERKS-LOW = '1000'.
  S_WERKS-HIGH = '3000'.
  APPEND S_WERKS.
  S_MATNR-LOW = '100-100'.
  S_MATNR-HIGH = '100-120'.
  S_MATNR-SIGN = 'I'.
  S_MATNR-OPTION = 'BT'.
  APPEND S_MATNR.


  TYPES: BEGIN OF MARA_TY,
           MATNR TYPE MATNR,
           MTART TYPE MTART,
           MBRSH TYPE MBRSH,
           MATKL TYPE MATKL,
           MEINS TYPE MEINS,
         END OF MARA_TY,

         BEGIN OF MARC_TY,
           MATNR TYPE MATNR,
           WERKS TYPE WERKS_D,
           EKGRP TYPE EKGRP,
           MINBE TYPE MINBE,
           BSTMI TYPE BSTMI,
         END OF MARC_TY,

         BEGIN OF MARD_TY,
           MATNR TYPE MATNR,
           WERKS TYPE WERKS_D,
           LGORT TYPE LGORT_D,
           LABST TYPE LABST,
         END OF MARD_TY,

         BEGIN OF MAKT_TY,
           MATNR TYPE MATNR,
           SPRAS TYPE SPRAS,
           MAKTX TYPE MAKTX,
         END OF MAKT_TY,

         BEGIN OF MBEW_TY,
           MATNR TYPE MATNR,
           BWKEY TYPE BWKEY,
           BWTAR TYPE BWTAR_D,
           STPRS TYPE STPRS,
         END OF MBEW_TY.

  DATA: IT_MARA TYPE TABLE OF MARA_TY,
        WA_MARA TYPE MARA_TY,

        IT_MARC TYPE TABLE OF MARC_TY,
        WA_MARC TYPE MARC_TY,

        IT_MARD TYPE TABLE OF MARD_TY,
        WA_MARD TYPE MARD_TY,

        IT_MAKT TYPE TABLE OF MAKT_TY,
        WA_MAKT TYPE MAKT_TY,

        IT_MBEW TYPE TABLE OF MBEW_TY,
        WA_MBEW TYPE MBEW_TY.


  TYPES: BEGIN OF F_TY,
           MATNR TYPE MATNR,
           MTART TYPE MTART,
           MBRSH TYPE MBRSH,
           MATKL TYPE MATKL,
           MEINS TYPE MEINS,
           WERKS TYPE WERKS_D,
           EKGRP TYPE EKGRP,
           MINBE TYPE MINBE,
           BSTMI TYPE BSTMI,
           LGORT TYPE LGORT_D,
           LABST TYPE LABST,
           SPRAS TYPE SPRAS,
           MAKTX TYPE MAKTX,
           BWKEY TYPE BWKEY,
           BWTAR TYPE BWTAR_D,
           STPRS TYPE STPRS,
         END OF F_TY.

  DATA: IT_F TYPE TABLE OF F_TY,
        WA_F TYPE F_TY.

  DATA :WA_FCAT TYPE SLIS_FIELDCAT_ALV,
        IT_FCAT TYPE SLIS_T_FIELDCAT_ALV.

AT SELECTION-SCREEN.
  PERFORM BUTTON.
  PERFORM VALIDATION.

START-OF-SELECTION.
  PERFORM FETCH_DATA.
  PERFORM PROCESS_DATA.
  PERFORM FIELD_CAT.
  PERFORM DISPLAY.

FORM VALIDATION .

  IF S_WERKS IS NOT INITIAL.
    SELECT SINGLE WERKS FROM T001W INTO @DATA(V_WERKS)
    WHERE WERKS IN @S_WERKS .
    IF SY-SUBRC <> 0.
      MESSAGE 'ENTER VALID PLANT' TYPE 'E'.
    ENDIF.
  ENDIF.

  IF S_MATNR[] IS NOT INITIAL.
    SELECT SINGLE MATNR FROM MARA INTO @DATA(V_MATNR)
    WHERE MATNR IN @S_MATNR  .
    IF SY-SUBRC <> 0.
      MESSAGE 'ENTER VALID MATERIAL NO' TYPE 'E'.
    ENDIF.
  ENDIF.

  IF S_MTART[] IS NOT INITIAL.
    SELECT SINGLE MTART FROM T134 INTO @DATA(V_MTART)
    WHERE MTART IN @S_MTART .
    IF SY-SUBRC <> 0.
      MESSAGE 'ENTER VALID MATERIAL TYPE' TYPE 'E'.
    ENDIF.
  ENDIF.

  IF S_MATKL[] IS NOT INITIAL.
    SELECT SINGLE MATKL FROM T023 INTO @DATA(V_MATKL)
    WHERE MATKL IN @S_MATKL  .
        IF SY-SUBRC <> 0.
      MESSAGE 'ENTER VALID MATRIAL GROUP' TYPE 'E'.
    ENDIF.
  ENDIF.
ENDFORM.

FORM FETCH_DATA .
  SELECT MATNR MTART MBRSH MATKL MEINS  FROM MARA INTO TABLE IT_MARA
    WHERE MATNR IN S_MATNR AND MTART IN S_MTART AND MATKL IN S_MATKL.

  IF IT_MARA IS NOT INITIAL .
    SELECT MATNR WERKS EKGRP MINBE BSTMI FROM MARC INTO TABLE IT_MARC
    FOR ALL ENTRIES IN IT_MARA WHERE MATNR = IT_MARA-MATNR AND WERKS IN S_WERKS.
  ENDIF.

  IF IT_MARC IS NOT INITIAL.
    SELECT MATNR WERKS LGORT LABST FROM MARD INTO TABLE IT_MARD
      FOR ALL ENTRIES IN IT_MARC WHERE MATNR = IT_MARC-MATNR AND WERKS = IT_MARC-WERKS.
  ENDIF.

  IF IT_MARC IS NOT INITIAL.
    SELECT MATNR BWKEY BWTAR STPRS FROM MBEW INTO TABLE IT_MBEW
      FOR ALL ENTRIES IN IT_MARC WHERE MATNR = IT_MARC-MATNR AND BWKEY = IT_MARC-WERKS.
  ENDIF.

  IF IT_MARC IS NOT INITIAL.
    SELECT MATNR SPRAS MAKTX FROM MAKT INTO TABLE IT_MAKT
      FOR ALL ENTRIES IN IT_MARC WHERE MATNR = IT_MARC-MATNR AND SPRAS = SY-LANGU.
  ENDIF.

ENDFORM.

FORM PROCESS_DATA .
  DATA QTY TYPE MARD-LABST.
  SORT IT_MARA BY MATNR.
  SORT IT_MAKT BY MATNR.
  SORT IT_MBEW BY MATNR BWKEY.

  LOOP AT  IT_MARC INTO WA_MARC.

    WA_F-MATNR = WA_MARC-MATNR.
    WA_F-WERKS = WA_MARC-WERKS.
    WA_F-EKGRP = WA_MARC-EKGRP.
    WA_F-MINBE = WA_MARC-MINBE.
    WA_F-BSTMI = WA_MARC-BSTMI.


    READ TABLE IT_MARA INTO WA_MARA WITH KEY MATNR = WA_MARC-MATNR BINARY SEARCH.
    IF SY-SUBRC = 0.
      WA_F-MTART = WA_MARA-MTART.
      WA_F-MBRSH = WA_MARA-MBRSH.
      WA_F-MATKL = WA_MARA-MATKL.
      WA_F-MEINS = WA_MARA-MEINS.
    ENDIF.

    LOOP AT IT_MARD INTO WA_MARD WHERE MATNR = WA_MARC-MATNR AND WERKS = WA_MARC-WERKS.
      QTY = QTY + WA_MARD-LABST.
    ENDLOOP.
    WA_F-LABST = QTY.
    WA_F-LGORT = WA_MARD-LGORT.

    READ TABLE IT_MAKT INTO WA_MAKT WITH KEY MATNR = WA_MARC-MATNR BINARY SEARCH.

    IF SY-SUBRC = 0.
      WA_F-MAKTX = WA_MAKT-MAKTX.
    ENDIF.

    READ TABLE IT_MBEW INTO WA_MBEW WITH KEY MATNR = WA_MARC-MATNR  BWKEY = WA_MARC-WERKS BINARY SEARCH.
    IF SY-SUBRC = 0.
      WA_F-BWKEY = WA_MBEW-BWKEY.
      WA_F-BWTAR = WA_MBEW-BWTAR.
      WA_F-STPRS = WA_MBEW-STPRS.
    ENDIF.

    IF R1 = 'X'.
      IF QTY < WA_MARC-MINBE.
        APPEND WA_F TO IT_F.

      ENDIF.
      CLEAR : WA_MARA,WA_MARC,WA_MARD,WA_MAKT,WA_MBEW,WA_F,QTY.

    ELSEIF R2 = 'X'.
      APPEND WA_F TO IT_F.
      CLEAR : WA_MARA,WA_MARC,WA_MARD,WA_MAKT,WA_MBEW,WA_F,QTY.
    ENDIF.

  ENDLOOP.
ENDFORM.

FORM FIELD_CAT .

  WA_FCAT-COL_POS = 1.
  WA_FCAT-FIELDNAME = 'MATNR' .
  WA_FCAT-KEY = 'X'.
  WA_FCAT-SELTEXT_M = 'MATERIAL NO'.
  WA_FCAT-JUST = 'c'.
  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.

  WA_FCAT-COL_POS = 2.
  WA_FCAT-FIELDNAME = 'MTART' .
  WA_FCAT-SELTEXT_M = 'Material Type'.
  WA_FCAT-JUST = 'c'.
  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.

  WA_FCAT-COL_POS = 3.
  WA_FCAT-FIELDNAME = 'MBRSH' .
  WA_FCAT-SELTEXT_M = 'INDUSTRY SECTOR'.
  WA_FCAT-JUST = 'c'.
  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.

  WA_FCAT-COL_POS = 4.
  WA_FCAT-FIELDNAME = 'MATKL' .
  WA_FCAT-SELTEXT_M = 'MATERIAL GROUP'.
  WA_FCAT-JUST = 'c'.
  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.

  WA_FCAT-COL_POS = 5.
  WA_FCAT-FIELDNAME = 'MEINS' .
  WA_FCAT-SELTEXT_M = 'UNIT OF MESSURE'.
  WA_FCAT-JUST = 'c'.
  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.

  WA_FCAT-COL_POS = 6.
  WA_FCAT-FIELDNAME = 'WERKS' .
  WA_FCAT-SELTEXT_M = 'PLANT'.
  WA_FCAT-JUST = 'c'.
  WA_FCAT-EMPHASIZE = 'C715' .
  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.

  WA_FCAT-COL_POS = 7.
  WA_FCAT-FIELDNAME = 'EKGRP' .
  WA_FCAT-SELTEXT_M = 'PURCHASING GROUP'.
  WA_FCAT-JUST = 'c'.
  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.

  WA_FCAT-COL_POS = 8.
  WA_FCAT-FIELDNAME = 'MINBE' .
  WA_FCAT-SELTEXT_M = 'REORDER POINT'.
  WA_FCAT-JUST = 'c'.
  WA_FCAT-EMPHASIZE = 'C515' .
  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.

  WA_FCAT-COL_POS = 9.
  WA_FCAT-FIELDNAME = 'BSTMI' .
  WA_FCAT-SELTEXT_M = 'MINMUM LOT SIZE'.
  WA_FCAT-JUST = 'c'.
  WA_FCAT-EMPHASIZE = 'C415' .
  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.

  WA_FCAT-COL_POS = 10.
  WA_FCAT-FIELDNAME = 'LGORT' .
  WA_FCAT-SELTEXT_M = 'STORAGE LOCATION'.
  WA_FCAT-JUST = 'c'.
  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.

  WA_FCAT-COL_POS = 11.
  WA_FCAT-FIELDNAME = 'LABST' .
  WA_FCAT-SELTEXT_M = 'UNRESTRICTED USE STOCK'.
  WA_FCAT-EMPHASIZE = 'C315' .
  WA_FCAT-JUST = 'c'.
  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.

  WA_FCAT-COL_POS = 12.
  WA_FCAT-FIELDNAME = 'BWKEY' .
  WA_FCAT-SELTEXT_M = 'VALUATION AREA'.
  WA_FCAT-JUST = 'c'.
  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.

  WA_FCAT-COL_POS = 15.
  WA_FCAT-FIELDNAME = 'BWTAR' .
  WA_FCAT-SELTEXT_M = 'VALUATION TYPE'.
  WA_FCAT-JUST = 'c'.
  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.

  WA_FCAT-COL_POS = 14.
  WA_FCAT-FIELDNAME = 'STPRS' .
  WA_FCAT-SELTEXT_M = 'STANDERD PRICE'.
  WA_FCAT-EMPHASIZE = 'C215' .
  WA_FCAT-JUST = 'c'.
  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.

  WA_FCAT-COL_POS = 13.
  WA_FCAT-FIELDNAME = 'MAKTX' .
  WA_FCAT-SELTEXT_M = 'MATERIAL DISCRIPTIONS'.
  WA_FCAT-JUST = 'c'.
  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.
ENDFORM.

*----------------------------------------------------------------------*
FORM DISPLAY .
  CALL FUNCTION 'REUSE_ALV_GRID_DISPLAY'
    EXPORTING
      I_CALLBACK_PROGRAM = SY-REPID
      I_GRID_TITLE       = ' RE-ORDER ALV REPORT '
      IT_FIELDCAT        = IT_FCAT
    TABLES
      T_OUTTAB           = IT_F
    EXCEPTIONS
      PROGRAM_ERROR      = 1
      OTHERS             = 2.
  IF SY-SUBRC <> 0.
* Implement suitable error handling here
  ENDIF.

ENDFORM.

FORM BUTTON .
  IF SSCRFIELDS-UCOMM = 'FCT2'.
    LEAVE PROGRAM.
  ELSEIF SSCRFIELDS-UCOMM = 'FCT1'.
    SSCRFIELDS-UCOMM = 'ONLI'.
  ENDIF.
ENDFORM.
