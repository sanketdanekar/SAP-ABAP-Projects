REPORT Z_CONTROL_CODE_REPORT.
*DEDEVELOP THE ALV REPORT TO DISPLAY MATERIAL WITH CONTROL CODES
*TABLES: MARA, MARC, MAKT, MBEW, MVKE.
TABLES:SSCRFIELDS.
DATA: M TYPE MTART,
      S TYPE STEUC,
      W TYPE MARC-WERKS.

SELECT-OPTIONS: S_MTART FOR M,
                S_STEUC FOR S,
                S_WERKS FOR W.

SELECTION-SCREEN SKIP 2.
SELECTION-SCREEN PUSHBUTTON 30(10) BUTTON1 USER-COMMAND FCT1.
SELECTION-SCREEN PUSHBUTTON 60(10) BUTTON2 USER-COMMAND FCT2.

INITIALIZATION.
  BUTTON1 = 'DISPLAY'.
  BUTTON2 = 'EXIT'.
  S_WERKS-LOW = '7000'.
  S_WERKS-HIGH = '7010'.
  APPEND S_WERKS.




  TYPES :BEGIN OF TY_MARA,
           MATNR TYPE MATNR,
           MTART TYPE MTART,
           MATKL TYPE MATKL,
           MEINS TYPE MEINS,
           ERNAM TYPE ERNAM,
           ERSDA TYPE ERSDA,
           MBRSH TYPE MBRSH,
         END OF TY_MARA,

         BEGIN OF TY_MARC,
           MATNR TYPE  MATNR,
           WERKS TYPE WERKS_D,
           EKGRP TYPE EKGRP,
           STEUC TYPE STEUC,
         END OF TY_MARC,

         BEGIN OF TY_MAKT,
           MATNR TYPE MATNR,
           SPRAS TYPE SPRAS,
           MAKTX TYPE MAKTX,
         END OF TY_MAKT,

         BEGIN OF TY_MBEW,
           MATNR TYPE MATNR,
           BWKEY TYPE BWKEY,
           BWTAR TYPE BWTAR_D,
           BKLAS TYPE BKLAS,
         END OF TY_MBEW,

         BEGIN OF TY_MVKE,
           MATNR TYPE MATNR,
           VKORG TYPE VKORG,
           VTWEG TYPE VTWEG,
           DWERK TYPE DWERK,
           KTGRM TYPE KTGRM,
         END OF TY_MVKE.

  TYPES : BEGIN OF TY_FINAL,
            MATNR TYPE MATNR,
            MTART TYPE MTART,
            MATKL TYPE MATKL,
            MEINS TYPE MEINS,
            ERNAM TYPE ERNAM,
            ERSDA TYPE ERSDA,
            MBRSH TYPE MBRSH,
            WERKS TYPE WERKS_D,
            EKGRP TYPE EKGRP,
            STEUC TYPE STEUC,
            SPRAS TYPE SPRAS,
            MAKTX TYPE MAKTX,
            BWKEY TYPE BWKEY,
            BWTAR TYPE BWTAR_D,
            BKLAS TYPE BKLAS,
            VKORG TYPE VKORG,
            VTWEG TYPE VTWEG,
            DWERK TYPE DWERK,
            KTGRM TYPE KTGRM,
          END OF TY_FINAL.

  DATA : IT_MARA TYPE TABLE OF TY_MARA,
         WA_MARA TYPE TY_MARA,

         IT_MARC TYPE TABLE OF TY_MARC,
         WA_MARC TYPE TY_MARC,

         IT_MAKT TYPE TABLE OF TY_MAKT,
         WA_MAKT TYPE TY_MAKT,

         IT_MBEW TYPE TABLE OF TY_MBEW,
         WA_MBEW TYPE TY_MBEW,

         IT_MVKE TYPE TABLE OF TY_MVKE,
         WA_MVKE TYPE TY_MVKE.


  DATA : IT_LAST TYPE TABLE OF TY_FINAL,
         WA_LAST TYPE TY_FINAL.

  DATA: WA_FCAT TYPE SLIS_FIELDCAT_ALV,
        IT_FCAT TYPE SLIS_T_FIELDCAT_ALV.

AT SELECTION-SCREEN.
  PERFORM BUTTON.

START-OF-SELECTION.
  PERFORM FETCH_DATA.
  PERFORM PROCESS_DATA.
  PERFORM FIELD_CAT.
  PERFORM DISPLAY_ALV.

FORM FETCH_DATA .
  SELECT MATNR MTART MATKL MEINS ERNAM ERSDA MBRSH FROM MARA INTO TABLE IT_MARA WHERE MTART IN S_MTART.

  IF IT_MARA IS NOT INITIAL.
    SELECT MATNR
           WERKS
           EKGRP
           STEUC FROM MARC INTO TABLE IT_MARC FOR ALL ENTRIES IN IT_MARA WHERE MATNR = IT_MARA-MATNR AND WERKS IN S_WERKS AND STEUC IN S_STEUC.
  ENDIF.

  IF IT_MARA IS NOT INITIAL.
    SELECT MATNR SPRAS MAKTX FROM MAKT INTO TABLE IT_MAKT FOR ALL ENTRIES IN IT_MARA WHERE MATNR = IT_MARA-MATNR AND SPRAS = 'EN'.
  ENDIF.

  IF IT_MARC IS NOT INITIAL.
    SELECT MATNR BWKEY BWTAR BKLAS FROM MBEW INTO TABLE IT_MBEW FOR ALL ENTRIES IN IT_MARC WHERE MATNR = IT_MARC-MATNR AND BWKEY = IT_MARC-WERKS.
  ENDIF.

  IF IT_MARC IS NOT INITIAL.
    SELECT MATNR VKORG VTWEG DWERK KTGRM FROM MVKE INTO TABLE IT_MVKE FOR ALL ENTRIES IN IT_MARC WHERE MATNR = IT_MARC-MATNR AND DWERK = IT_MARC-WERKS.
  ENDIF.

ENDFORM.

FORM PROCESS_DATA .

  SORT IT_MARA BY MATNR.
  SORT IT_MAKT BY MATNR.
  SORT IT_MBEW BY MATNR BWKEY.
  SORT IT_MVKE BY MATNR  DWERK.

  LOOP AT IT_MARC INTO WA_MARC.
    WA_LAST-MATNR = WA_MARC-MATNR.
    WA_LAST-WERKS = WA_MARC-WERKS.
    WA_LAST-EKGRP = WA_MARC-EKGRP.
    WA_LAST-STEUC = WA_MARC-STEUC.

    READ TABLE IT_MARA INTO WA_MARA WITH KEY MATNR = WA_MARC-MATNR BINARY SEARCH.
    WA_LAST-MTART = WA_MARA-MTART.
    WA_LAST-MATKL = WA_MARA-MATKL.
    WA_LAST-MEINS = WA_MARA-MEINS.
    WA_LAST-ERNAM = WA_MARA-ERNAM.
    WA_LAST-ERSDA = WA_MARA-ERSDA.
    WA_LAST-MBRSH = WA_MARA-MBRSH.

    READ TABLE IT_MAKT INTO WA_MAKT WITH KEY MATNR = WA_MARC-MATNR   SPRAS = SY-LANGU BINARY SEARCH.
    WA_LAST-SPRAS = WA_MAKT-SPRAS.
    WA_LAST-MAKTX = WA_MAKT-MAKTX.

    READ TABLE IT_MBEW INTO WA_MBEW WITH KEY MATNR = WA_MARC-MATNR   BWKEY = WA_MARC-WERKS BINARY SEARCH.
    WA_LAST-BWKEY =  WA_MBEW-BWKEY.
    WA_LAST-BWTAR =  WA_MBEW-BWTAR.
    WA_LAST-BKLAS =  WA_MBEW-BKLAS.

    READ TABLE IT_MVKE INTO WA_MVKE WITH KEY MATNR = WA_MARC-MATNR   DWERK = WA_MARC-WERKS BINARY SEARCH.
    WA_LAST-VKORG = WA_MVKE-VKORG.
    WA_LAST-VTWEG = WA_MVKE-VTWEG.
    WA_LAST-DWERK = WA_MVKE-DWERK.
    WA_LAST-KTGRM = WA_MVKE-KTGRM.

    APPEND WA_LAST TO IT_LAST.
    CLEAR : WA_MARA, WA_MARC, WA_MAKT, WA_MBEW, WA_MVKE.
  ENDLOOP.
ENDFORM.

FORM FIELD_CAT .
  WA_FCAT-COL_POS = 1.
  WA_FCAT-FIELDNAME = 'MATNR' .
  WA_FCAT-KEY = 'X'.
  WA_FCAT-SELTEXT_M = 'MATERIAL NO'.
  WA_FCAT-JUST = 'c'.
  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.

  WA_FCAT-COL_POS = 2.
  WA_FCAT-FIELDNAME = 'MTART' .
  WA_FCAT-SELTEXT_M = 'Material Type'.
  WA_FCAT-JUST = 'c'.
  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.

  WA_FCAT-COL_POS = 3.
  WA_FCAT-FIELDNAME = 'MBRSH' .
  WA_FCAT-SELTEXT_M = 'INDUSTRY SECTOR'.
  WA_FCAT-JUST = 'c'.
  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.

  WA_FCAT-COL_POS = 4.
  WA_FCAT-FIELDNAME = 'MATKL' .
  WA_FCAT-SELTEXT_M = 'MATERIAL GROUP'.
  WA_FCAT-JUST = 'c'.
  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.

  WA_FCAT-COL_POS = 5.
  WA_FCAT-FIELDNAME = 'MEINS' .
  WA_FCAT-SELTEXT_M = 'UNIT OF MESSURE'.
  WA_FCAT-JUST = 'c'.
  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.

  WA_FCAT-COL_POS = 6.
  WA_FCAT-FIELDNAME = 'ERNAM' .
  WA_FCAT-SELTEXT_M = 'CREATED BY'.
  WA_FCAT-JUST = 'c'.
  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.

  WA_FCAT-COL_POS = 7.
  WA_FCAT-FIELDNAME = 'ERSDA' .
  WA_FCAT-SELTEXT_M = 'CREATED ON'.
  WA_FCAT-JUST = 'c'.
  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.

  WA_FCAT-COL_POS = 8.
  WA_FCAT-FIELDNAME = 'WERKS' .
  WA_FCAT-SELTEXT_M = 'PLANT'.
  WA_FCAT-JUST = 'c'.
  WA_FCAT-EMPHASIZE = 'C715' .
  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.

  WA_FCAT-COL_POS = 9.
  WA_FCAT-FIELDNAME = 'EKGRP' .
  WA_FCAT-SELTEXT_M = 'PURCHASING GROUP'.
  WA_FCAT-JUST = 'c'.
  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.

  WA_FCAT-COL_POS = 10.
  WA_FCAT-FIELDNAME = 'STEUC' .
  WA_FCAT-SELTEXT_M = 'CONTROL CODES'.
  WA_FCAT-JUST = 'c'.
  WA_FCAT-EMPHASIZE = 'C515' .
  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.

  WA_FCAT-COL_POS = 11.
  WA_FCAT-FIELDNAME = 'MAKTX' .
  WA_FCAT-SELTEXT_M = 'MATERIAL DISCRIPTIONS'.
  WA_FCAT-JUST = 'c'.
  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.

  WA_FCAT-COL_POS = 12.
  WA_FCAT-FIELDNAME = 'BWKEY' .
  WA_FCAT-SELTEXT_M = 'VALUATION AREA'.
  WA_FCAT-JUST = 'c'.
  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.

  WA_FCAT-COL_POS = 13.
  WA_FCAT-FIELDNAME = 'BWTAR' .
  WA_FCAT-SELTEXT_M = 'VALUATION TYPE'.
  WA_FCAT-JUST = 'c'.
  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.

  WA_FCAT-COL_POS = 14.
  WA_FCAT-FIELDNAME = 'BKLAS' .
  WA_FCAT-SELTEXT_M = 'VALUATION CLASS'.
  WA_FCAT-EMPHASIZE = 'C215' .
  WA_FCAT-JUST = 'c'.
  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.

  WA_FCAT-COL_POS = 15.
  WA_FCAT-FIELDNAME = 'VKORG' .
  WA_FCAT-SELTEXT_M = 'SALES ORGANIZATION'.
  WA_FCAT-JUST = 'c'.
  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.

  WA_FCAT-COL_POS = 16.
  WA_FCAT-FIELDNAME = 'VTWEG' .
  WA_FCAT-SELTEXT_M = 'DISTRIBUTION CHANNEL'.
  WA_FCAT-JUST = 'c'.
  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.

  WA_FCAT-COL_POS = 17.
  WA_FCAT-FIELDNAME = 'DWERK' .
  WA_FCAT-SELTEXT_M = 'DELIVERY PLANT'.
  WA_FCAT-JUST = 'c'.
  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.

  WA_FCAT-COL_POS = 18.
  WA_FCAT-FIELDNAME = 'KTGRM' .
  WA_FCAT-SELTEXT_M = 'ACCOUNT ASSIGNMENT GROUP'.
  WA_FCAT-JUST = 'c'.
  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.
ENDFORM.

FORM DISPLAY_ALV .
  CALL FUNCTION 'REUSE_ALV_GRID_DISPLAY'
    EXPORTING
      I_CALLBACK_PROGRAM = SY-REPID
      I_GRID_TITLE       = 'REPORT ON CONTROL CODES'
      IT_FIELDCAT        = IT_FCAT
    TABLES
      T_OUTTAB           = IT_LAST
    EXCEPTIONS
      PROGRAM_ERROR      = 1
      OTHERS             = 2.
  IF SY-SUBRC <> 0.
* Implement suitable error handling here
  ENDIF.

ENDFORM.

FORM BUTTON .
  IF SSCRFIELDS-UCOMM = 'FCT2'.
    LEAVE PROGRAM.
  ELSEIF SSCRFIELDS-UCOMM = 'FCT1'.
    SSCRFIELDS-UCOMM = 'ONLI'.
  ENDIF.
ENDFORM.
